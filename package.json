{
  "name": "jen-lab",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --host",
    "generate": "nuxt generate",
    "analyze": "nuxt analyze --no-serve --logLevel=silent",
    "analyze:web": "nuxt analyze --serve --logLevel=silent",
    "analyze:ci": "pnpm analyze && cp ./node_modules/.cache/nuxt/.nuxt/dist/client/stats.json \"./analyze.client.${COMMIT_SHA:-$(git rev-parse HEAD)}.json\"",
    "preview": "npm run build && wrangler pages dev",
    "postinstall": "nuxt prepare",
    "deploy": "npm run build && wrangler pages deploy",
    "bundle-report": "node --experimental-strip-types scripts/bundle-report.ts"
  },
  "dependencies": {
    "@nuxt/ui": "^4.7.0",
    "@nuxtjs/color-mode": "^4.0.0",
    "@types/leaflet": "^1.9.21",
    "leaflet": "^1.9.4",
    "marked": "^18.0.2",
    "nuxt": "^4.4.2",
    "tailwindcss": "^4.2.2",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "nitro-cloudflare-dev": "^0.2.2",
    "vite-bundle-analyzer": "^1.3.7",
    "wrangler": "^4.83.0"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "packageManager": "pnpm@8.15.7"
}
