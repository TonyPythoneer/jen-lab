{
  "name": "jen-lab",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --host",
    "typecheck": "nuxt typecheck",
    "check": "vp check",
    "test": "vp test run",
    "test:watch": "vp test",
    "generate": "nuxt generate",
    "analyze": "nuxt analyze --no-serve --logLevel=silent",
    "analyze:web": "nuxt analyze --serve --logLevel=silent",
    "analyze:ci": "pnpm analyze && cp ./node_modules/.cache/nuxt/.nuxt/dist/client/stats.json \"./analyze.client.${COMMIT_SHA:-$(git rev-parse HEAD)}.json\"",
    "preview": "NUXT_CONTENT_DB=d1 npm run build && NUXT_CONTENT_DB=d1 wrangler pages dev",
    "postinstall": "nuxt prepare",
    "deploy": "NUXT_CONTENT_DB=d1 npm run build && wrangler pages deploy",
    "bundle-report": "node --experimental-strip-types scripts/bundle-report.ts",
    "cf-typegen": "wrangler types",
    "sync:wp": "node --experimental-strip-types scripts/sync-wp.ts",
    "prepare": "vp config"
  },
  "dependencies": {
    "@nuxt/content": "^3.13.0",
    "@nuxt/ui": "^4.7.1",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/mdc": "^0.21.1",
    "@types/leaflet": "^1.9.21",
    "@vueuse/nuxt": "^14.2.1",
    "@vueuse/router": "^14.3.0",
    "leaflet": "^1.9.4",
    "nuxt": "^4.4.4",
    "tailwindcss": "^4.2.2",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.6.0",
    "markdown-it": "^14.1.1",
    "markdown-it-link-attributes": "^4.0.1",
    "nitro-cloudflare-dev": "^0.2.2",
    "rolldown": "catalog:",
    "vite-bundle-analyzer": "^1.3.8",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "wrangler": "^4.86.0",
    "yaml": "^2.8.4"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "packageManager": "pnpm@11.0.3"
}
